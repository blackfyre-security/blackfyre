# Database
DATABASE_URL=postgres://blackfyre:blackfyre_dev@localhost:5432/blackfyre

# Redis
REDIS_URL=redis://:blackfyre_redis_dev@localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-a-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption — REQUIRED: the API fails closed at boot without key material.
# Any high-entropy secret works (it is SHA-256-normalized to a 32-byte AES key).
# Generate one with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3003

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/sso

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
WEBHOOK_SIGNING_SECRET=change-me-use-a-random-string

# AI
ANTHROPIC_API_KEY=

# AWS / Evidence Storage
AWS_REGION=ap-south-1
EVIDENCE_BUCKET=blackfyre-evidence

# Razorpay Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SAML SSO
SAML_SP_ENTITY_ID=https://app.blackfyre.in
SAML_ACS_URL=https://app.blackfyre.in/api/auth/saml/acs

# SQS Queue URLs (set by SST at deploy time)
SCAN_QUEUE_URL=
MONITOR_QUEUE_URL=
AI_QUEUE_URL=
EVIDENCE_QUEUE_URL=

# Scanner ARNs (set by SST at deploy time)
SCAN_ARTIFACTS_BUCKET=
PROWLER_SCANNER_ARN=
IAC_SCANNER_ARN=

# Monitoring
SENTRY_DSN=
