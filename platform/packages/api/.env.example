# ============================================================
# BLACKFYRE API — Environment Variables Reference
# Copy to .env and fill in real values before running locally.
# ============================================================

DATABASE_URL=postgres://blackfyre:blackfyre_dev@localhost:5432/blackfyre
REDIS_URL=redis://:blackfyre_redis_dev@localhost:6379
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:3003

JWT_SECRET=dev-only-secret-replace-in-production!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Field-level encryption — REQUIRED: the API fails closed at boot without key
# material. Any high-entropy secret works (it is SHA-256-normalized to a
# 32-byte AES-256 key). Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# SMTP — leave SMTP_HOST empty to disable email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@blackfyre.tech

WEBHOOK_SIGNING_SECRET=

# Google OAuth SSO — leave GOOGLE_CLIENT_ID empty to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# AWS / S3
EVIDENCE_BUCKET=
SCAN_ARTIFACTS_BUCKET=
AWS_REGION=ap-south-1

ANTHROPIC_API_KEY=

# SQS queues
SCAN_QUEUE_URL=
MONITOR_QUEUE_URL=
AI_QUEUE_URL=
EVIDENCE_QUEUE_URL=

# Prowler + IaC Scanner
PROWLER_SCANNER_ARN=
IAC_SCANNER_ARN=

# ---------------------------------------------------------------
# Payments — Razorpay (India / INR)
# Default gateway for users whose country resolves to IN.
# Leave empty to disable Razorpay.
# ---------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------------
# Payments — Stripe (international / USD)
# Default gateway for users outside India.
# Leave empty to disable Stripe.
# Obtain keys at https://dashboard.stripe.com/apikeys
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: pre-created recurring price IDs in your Stripe dashboard.
# If blank, the checkout route creates inline price_data instead.
STRIPE_PRICE_ID_COMPLY=
STRIPE_PRICE_ID_PROTECT=
STRIPE_PRICE_ID_DEFEND=

# SAML SP
SAML_SP_ENTITY_ID=https://app.blackfyre.tech
SAML_ACS_URL=https://app.blackfyre.tech/api/auth/saml/acs

# ---------------------------------------------------------------
# Sentry — error reporting / observability
# Setting SENTRY_DSN to a real DSN ENABLES error reporting: the API
# initializes Sentry at boot and ships unhandled errors + traces.
# Leave it EMPTY to disable Sentry entirely (no-op, nothing sent).
# Get the DSN from https://sentry.io — do NOT commit real values.
# ---------------------------------------------------------------
SENTRY_DSN=
# Optional: tags events with a release/version for grouping & regressions.
SENTRY_RELEASE=
