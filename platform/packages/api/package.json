{
  "name": "@blackfyre/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "demo": "tsx src/demo-server-runner.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:smoke": "STAGING_SMOKE=1 vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts",
    "migrate:sql": "tsx --env-file-if-exists=.env src/migrations/run.ts"
  },
